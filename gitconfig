[user]
  name = Francisco Nevitt Gonçalves
  email = git@francisco.wiki

[init]
  defaultBranch = main

[core]
  editor = nvim
  excludesfile = ~/.gitignore
  untrackedCache = true
  # To bypass delta (e.g. when producing a patch), use `git --no-pager diff` or `git -c core.pager=cat diff`.
  pager = delta

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true

[color]
  ui = auto

[column]
  ui = auto

[branch]
  sort = -committerdate

[tag]
  sort = version:refname

[push]
  default = simple
  autoSetupRemote = true

[pull]
  rebase = true

[fetch]
  prune = true
  pruneTags = true
  all = true

[diff]
  algorithm = histogram
  colorMoved = plain
  mnemonicPrefix = true
  renames = true

[merge]
  conflictstyle = zdiff3
	tool = nvimdiff

[commit]
  verbose = true

[rebase]
  autoStash = true
  updateRefs = true

[rerere]
	enabled = true
  autoupdate = true

[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
[mergetool]
	keepBackup = false
